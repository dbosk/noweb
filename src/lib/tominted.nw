def autolang_main():
    """Annotate a markup stream, or list its languages with ``-list``."""
    list_languages = False
    for argument in sys.argv[1:]:
        if argument in ("-list", "--list-languages"):
            list_languages = True
        elif not add_mapping(argument):
            print("autolang: unknown argument:", argument,
                  file=sys.stderr)
            sys.exit(1)
    lines = sys.stdin.read().split("\n")
    if lines and lines[-1] == "":
        lines.pop()
    langs, _ = chunk_languages(lines)
    if list_languages:
        for language in sorted(set(langs.values())):
            print(language)
    else:
        for line in annotate(lines, langs):
            print(line)
